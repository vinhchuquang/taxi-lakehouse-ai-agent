PROJECT_NAME=taxi-lakehouse-ai-agent
AIRFLOW_UID=50000

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=taxi-lakehouse
DUCKDB_S3_ENDPOINT=minio:9000
DUCKDB_S3_REGION=us-east-1
DUCKDB_S3_URL_STYLE=path
DUCKDB_S3_USE_SSL=false

LOCAL_DATA_ROOT=/opt/airflow/data
TLC_DOWNLOAD_TIMEOUT_SECONDS=300
TLC_LOOKBACK_MONTHS=3
DBT_PROJECT_DIR=/opt/airflow/dbt
DBT_PROFILES_DIR=/opt/airflow/.dbt
DBT_DUCKDB_PATH=/opt/airflow/warehouse/analytics.duckdb

DUCKDB_PATH=/data/warehouse/analytics.duckdb

OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ANSWER_SYNTHESIS=false

API_HOST=0.0.0.0
API_PORT=8000
